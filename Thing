local function tween(object, info, propertyTable)
    local t = TweenService:Create(object, TweenInfo.new(unpack(info)), propertyTable)
    t:Play()
    return t
end
--
local function setupButtonEffects(button, baseBgColor, targetBgColor)
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            tween(button, {0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {BackgroundColor3 = targetBgColor})
        end
    end)
    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            tween(button, {0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out}, {BackgroundColor3 = baseBgColor})
        end
    end)
end

